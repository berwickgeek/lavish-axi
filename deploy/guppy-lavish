#!/usr/bin/env bash
# guppy-lavish — open an HTML artifact in Lavish Editor, fronted on the Guppy tailnet.
#
# Lavish assumes a local desktop browser; Guppy has none. The warm Lavish server
# (systemd guppy-lavish-server, loopback :7803, base-path /lavish) is fronted by the
# launcher's /lavish reverse-proxy under one tailnet origin. This wrapper just rewrites
# Lavish's http://host:7803/lavish/... link to the launcher origin https://host/lavish/...
# Tailnet-only, same trust model as the launcher/shelf. Never binds 0.0.0.0.
#
# Usage:
#   guppy-lavish new <file.html> [--title "…"] [--lede "…"]
#                                     scaffold a complete Kit page with an empty gk-body region
#   guppy-lavish classes              print the ~25-line gk- class cheat-sheet (not the CSS)
#   guppy-lavish <file.html>          pre-flight + open/resume a session, print the tailnet URL
#   guppy-lavish check <file.html>    pre-flight only: audit layout at phone/iPad widths
#   guppy-lavish poll <file.html>     long-poll for the user's annotations (leave running)
#   guppy-lavish note <file.html> "…" post a live progress step to the "Working" indicator
#   guppy-lavish end  <file.html>     end the session as the agent
#   guppy-lavish stop                 shut the background server down
#   guppy-lavish kit                  print the raw Kit CSS+JS (rarely needed — prefer new/classes)
#
# Opens run a pre-flight layout audit (same thresholds as the in-browser audit) in
# headless Chromium at 402/810/1080px BEFORE printing the URL, so overflow is fixed
# before the human ever sees the page instead of via a live roundtrip. --force skips it.
set -euo pipefail

PORT=7803                       # warm-server loopback bind (7800-2 launcher/shelf/imsg, 7810 browser)
HOSTNAME_TS=guppy.tail72863e.ts.net

export LAVISH_AXI_HOST=127.0.0.1
export LAVISH_AXI_PORT="$PORT"
export LAVISH_AXI_LINK_HOST="$HOSTNAME_TS"
# Match the warm systemd server: if this wrapper ever spawns a server (e.g. during a
# restart window), it must be base-path aware too, or it emits root URLs the launcher
# /lavish proxy can't serve.
export LAVISH_AXI_BASE_PATH=/lavish

# rewrite Lavish's http://host:7803/lavish/... into the launcher origin https://host/lavish/...
rewrite() { sed -E "s#http://${HOSTNAME_TS}:${PORT}#https://${HOSTNAME_TS}#g"; }

FORK_DIR="${LAVISH_FORK_DIR:-$HOME/code/lavish-axi}"

preflight() { node "${FORK_DIR}/deploy/guppy-preflight.mjs" "$1"; }

cmd="${1:-}"
case "$cmd" in
  new)
    # Scaffold a full Kit page on disk — the CSS/JS never has to pass through the
    # authoring agent's context; it only writes the body between the gk-body markers.
    shift; node "${FORK_DIR}/deploy/guppy-scaffold.mjs" "$@" ;;
  classes)
    node -e "import('${FORK_DIR}/src/guppy-plan-kit.js').then(m=>process.stdout.write(m.GUPPY_PLAN_KIT_CHEATSHEET+'\n'))" ;;
  kit)
    # The Guppy Plan Kit: inline CSS + decision-widget JS, single-sourced from the fork.
    # Paste the CSS into <head> and the JS before </body>; build with gk- classes.
    node -e "import('${FORK_DIR}/src/guppy-plan-kit.js').then(m=>process.stdout.write(m.GUPPY_PLAN_KIT_CSS+'\n'+m.GUPPY_PLAN_KIT_DECISION_JS+'\n'))" ;;
  check)
    shift; preflight "${1:?usage: guppy-lavish check <file.html>}" ;;
  poll|note|end|stop|export|share|playbook|design|update)
    exec lavish-axi "$@" 2> >(rewrite >&2) | rewrite ;;
  ""|-h|--help)
    echo "usage: guppy-lavish new <file.html> [--title …] | classes | <file.html> [--force] | check <file.html> | poll <file.html> | note <file.html> \"…\" | end <file.html> | stop | kit"; exit 0 ;;
  *)
    # open/resume: pre-flight first so broken layout never reaches the reviewer's device.
    args=(); force=0
    for a in "$@"; do [[ "$a" == "--force" ]] && force=1 || args+=("$a"); done
    if [[ $force -eq 0 ]]; then
      preflight "${args[0]}" || { echo "not opened — fix the findings above and re-run (or --force)" >&2; exit 1; }
    fi
    lavish-axi --no-open "${args[@]}" | rewrite ;;
esac
